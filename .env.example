# Supabase 配置（从 Supabase Dashboard 获取）
NEXT_PUBLIC_SUPABASE_URL=https://你的项目ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的匿名密钥
SUPABASE_SERVICE_ROLE_KEY=你的服务角色密钥（用于服务端操作）

# Kimi API 配置（从 https://platform.moonshot.cn 获取 API Key）
KIMI_API_KEY=你的Kimi API Key

# 邮件 SMTP 配置（QQ邮箱/163邮箱）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=你的QQ邮箱@qq.com
SMTP_PASS=你的SMTP授权码（不是邮箱密码）

# 发件人显示名称
FROM_NAME=保供早报
FROM_EMAIL=你的QQ邮箱@qq.com

# 商务部抓取配置
MOFCOM_URL=https://www.mofcom.gov.cn/article/b/c/
